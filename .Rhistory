stringsAsFactors = FALSE)
# MD b3
f3 <- md_maxb3 ~ pb(age, by=sex, k=5) + pb(volume, k=5) + sex + s(dataset, bs='re') +s(scanner, bs='re') +s(TE, bs='re') +s(voxelsize, bs='re')+s(TR, bs='re') | s(dataset, bs='re')+s(scanner, bs='re')+s(TE, bs='re') +s(voxelsize, bs='re')+s(TR, bs='re')
winner_md <- select_gamlss2(f3, data = df, family = SHASH, criterion = "GCV", maxit = c(300, 100))
empty["AIC MD",]  <- new_formula_gd(winner_md)
# MK b3 + s(dataset, bs='re')+s(scanner, bs='re')
f4 <- mk_maxb3 ~ pb(age, by=sex, k=5) + pb(volume, k=5) + s(dataset, bs='re')+s(scanner, bs='re') + sex + s(TE, bs='re') +s(voxelsize, bs='re')+s(TR, bs='re')  | s(dataset, bs='re')+s(scanner, bs='re')+s(TE, bs='re') +s(voxelsize, bs='re')+s(TR, bs='re')
winner_mk <- select_gamlss2(f4, data = df, family = SHASH, criterion = "GCV", maxit = c(300, 100))
empty["AIC MK",] <- new_formula_gd(winner_mk)
# plot results
tth = ttheme("default")
p <- ggtexttable(empty, theme = tth)
p
# ---------------------------------------------------------------------------
# hierarchical GAM in ecology:  https://peerj.com/articles/6876/
# https://stats.stackexchange.com/questions/651564/fixed-effects-when-using-mgcv-and-bs-fs-in-gamm
#  y ~ s(x, bs = "cr") + s(x, f, bs = "fs", xt = list(bs = "cr"))
# best until now:
# f_md <- md_maxb3 ~ s(age, bs = "ps") + s(age, scanner, bs = "sz", xt = list(bs = "ps")) + scanner  | s(dataset, bs='re') + s(scanner, bs='re')
# ---------------------------------------------------------------------------
# Plot best model corrected data
# MD model
f_md <- md_maxb3 ~ sex + s(scanner, dataset, bs='re') + pb(age, by=sex, k=5) + pb(volume, k=5) | s(scanner, dataset, bs='re')
best_md_model <- gamlss2(f_md, data = df, family = SHASH, maxit = c(300, 100))
summary(best_md_model)
wormplot(best_md_model)
plot(best_md_model)
# MK model
f_mk <- mk_maxb3 ~ sex + s(scanner, dataset, bs='re') + pb(age, by=sex, k=5) + pb(volume, k=5) | s(scanner, dataset, bs='re')
best_mk_model <- gamlss2(f_mk, data = df, family = SHASH, maxit = c(300, 100))
summary(best_mk_model)
wormplot(best_mk_model)
plot(best_mk_model)
USE_WINNERS=TRUE
if (USE_WINNERS) {
best_md_model <- winner_md
best_mk_model <- winner_mk
}
this_plot <- function(dframe, xvar, yvar, fill, title='', ylab='', xlab='') {
p <- ggplot(dframe, aes(x = {{ xvar }}, y = {{ yvar }}, color = {{ fill }})) +
geom_point(alpha=0.15) +
geom_smooth(method = "lm", se = F) +
labs(title = title, x = xlab, y = ylab) +
scale_color_manual(values = scanner_colors) +
theme_pubr() +
theme(
legend.position = c(0.99, 0.99),
legend.justification = c("right", "top"),
legend.key.size = unit(0.2, "cm"),
legend.title = element_text(size = 8, face = "bold"),
legend.text = element_text(size = 7),
legend.margin = margin(t = 2, r = 1, b = 2, l = 1),
axis.text.x = element_text(angle = 45, hjust = 1)
)
return(p)
}
this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=dataset,
title="Dataset", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
this_plot <- function(dframe, xvar, yvar, fill, title='', ylab='', xlab='') {
p <- ggplot(dframe, aes(x = {{ xvar }}, y = {{ yvar }}, color = {{ fill }})) +
geom_point(alpha=0.15) +
geom_smooth(method = "lm", se = F) +
labs(title = title, x = xlab, y = ylab) +
scale_color_manual(values = scanner_colors) +
theme_pubr() +
theme(
legend.position = c(0.99, 0.99),
legend.justification = c("right", "top"),
legend.key.size = unit(0.2, "cm"),
legend.title = element_text(size = 8, face = "bold"),
legend.text = element_text(size = 7),
legend.margin = margin(t = 2, r = 1, b = 2, l = 1),
axis.text.x = element_text(angle = 45, hjust = 1)
)
return(p)
}
A1 <- this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=dataset,
title="Dataset", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
A2 <- this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=scanner,
title="Scanner", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
A3 <- this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=factor(TE),
title="TE", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
A4 <- this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=factor(TR),
title="TR", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
A5 <- this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=factor(voxelsize),
title="Voxel size [mm^3]", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
A6 <- this_plot(df_org, xvar=md_maxb3, yvar=mk_maxb3, fill=factor(ndir),
title="Number of directions", ylab="Mean Diffusivity (MD)", xlab="Mean Kurtosis (MK)")
# plot 1 the two together as subplots
plotA <-  ggarrange(A1, A3, A4, A2, A5, A6,
ncol = 3, nrow=2, align = "hv",
labels = c("A", "B", "C", "D", "E", "F"))
warnings()
plotA0 <- ggarrange(plotA, table_grob,
ncol = 1,
nrow = 2,
heights = c(0.45*3, 0.45),
widths = c(1, 1))
plotA0
