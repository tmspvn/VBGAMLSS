# ---------------------------------------------------------------------------
# hierarchical GAM in ecology:  https://peerj.com/articles/6876/
# https://stats.stackexchange.com/questions/651564/fixed-effects-when-using-mgcv-and-bs-fs-in-gamm
#  y ~ s(x, bs = "cr") + s(x, f, bs = "fs", xt = list(bs = "cr"))
# best until now:
# f_md <- md_maxb3 ~ s(age, bs = "ps") + s(age, scanner, bs = "sz", xt = list(bs = "ps")) + scanner  | s(dataset, bs='re') + s(scanner, bs='re')
# ---------------------------------------------------------------------------
# Plot best model corrected data
# MD model
f_md <- md_maxb3 ~ sex + s(scanner, dataset, bs='re') + pb(age, by=sex, k=5) + pb(volume, k=5) | s(scanner, dataset, bs='re')
best_md_model <- gamlss2(f_md, data = df, family = SHASH, maxit = c(300, 100))
summary(best_md_model)
wormplot(best_md_model)
plot(best_md_model)
# MK model
f_mk <- mk_maxb3 ~ sex + s(scanner, dataset, bs='re') + pb(age, by=sex, k=5) + pb(volume, k=5) | s(scanner, dataset, bs='re')
best_mk_model <- gamlss2(f_mk, data = df, family = SHASH, maxit = c(300, 100))
summary(best_mk_model)
wormplot(best_mk_model)
plot(best_mk_model)
USE_WINNERS=TRUE
if (USE_WINNERS) {
best_md_model <- winner_md
best_mk_model <- winner_mk
}
plot(best_mk_model)
