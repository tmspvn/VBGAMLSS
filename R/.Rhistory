# plot dist
ggplot(trimmed_fit_data, aes(x=ageM, fill=group)) + geom_density(alpha=.3)
# Compute all comparisons without plotting
tab_list <- lapply(1:12, make_plot, stir=T, rm.opt.test=T, hide.ns=T, maketable=T)
megatab <- data.table::rbindlist(tab_list)
# adjust uncorrected p-values with all other tests
megatab$p.adj <- p.adjust(megatab$p, method='fdr')
megatab$p.adj.signif <- signif.star(megatab$p.adj)
## changes review 1: 6/12/24
names(megatab)
megatab_supp = subset(megatab, select = -c(metric_org, estimate, conf.low, conf.high, p.adj))
# fill metric columns before reordering
megatab_supp$metric[seq(2, 24, by = 2)] <- megatab_supp$metric[seq(1, 23, by = 2)]
# split ep and sz
megatab_supp_ep <- subset(megatab_supp[megatab_supp$group2 == 'EP'], select = -c(group1, group2))
megatab_supp_sz <- subset(megatab_supp[megatab_supp$group2 == 'SZ'], select = -c(group1, group2))
# Sort
megatab_supp_ep <- megatab_supp_ep[order(abs(megatab_supp_ep$effsize), decreasing = T),]
megatab_supp_sz <- megatab_supp_sz[order(abs(megatab_supp_sz$effsize), decreasing = T),]
# plot pvals table
datasummary_df(data=megatab_supp_ep, fmt = fmt_significant(2),
output = 'latex_tabular')
#output = '/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/R_scripts/paper_plots_scripts/suppmat_table2_clinvshc.docx')
datasummary_df(data=megatab_supp_sz, fmt = fmt_significant(2),
output = 'latex_tabular')
grobs_list <- lapply(1:12, make_plot, stir=T, rm.opt.test=T, hide.ns=T,
precomp_comparison=megatab, inject=T)
gga <- ggarrange(plotlist = grobs_list, labels = 'AUTO')
theme_set(theme_minimal() +
theme(panel.grid = element_blank(),
panel.background = element_blank()))
gga
ggsave2(filename="/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/Paper1_Review/plots/TIFF/boxplot_4groups_lined.tiff",
gga, width = 35, height = 20, units = "cm", dpi=300, device='tiff')
ggsave2(filename="/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/Paper1_Review/plots/TIFF/boxplot_4groups_lined.tiff",
gga + theme_void(), width = 35, height = 20, units = "cm", dpi=300, device='tiff')
ggsave2(filename="/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/Paper1_Review/plots/TIFF/boxplot_4groups_lined.tiff",
