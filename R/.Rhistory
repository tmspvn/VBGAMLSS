control_by <- function(fit_data_res, vars=c("ageM", "sex"), from_ctrl=T, keep_intercept=T, variables=skeletons){
for (ic in seq_along(variables)){
coi <- variables[ic]
dt <- fit_data_res %>% subset(select=c(coi, vars, 'group'))
colnames(dt)[colnames(dt)==coi] <-'coi'
# fit model
if (from_ctrl){
dt_ctrl <- dt[dt$group == "CTRL",]
dt_clin <- dt[dt$group != "CTRL",]
formul <- paste("coi ~", vars)
lm_ <- lm(formul, data = dt_ctrl, na.action=na.exclude)
fit_data_res[fit_data_res$group == "CTRL", coi] <- residuals(lm_)
fit_data_res[fit_data_res$group != "CTRL", coi] <- dt_clin['coi'] - predict(lm_, dt_clin)
# add intercept
if (keep_intercept){
fit_data_res[, coi] <- fit_data_res[, coi] + coef(lm_)["(Intercept)"]
}
} else {
lm_ <- lm(coi ~ poly(ageM,2) + sex, data = dt, na.action=na.exclude)
fit_data_res[, coi] <- residuals(lm_)
if (keep_intercept){
fit_data_res[, coi] <- fit_data_res[, coi] + coef(lm_)["(Intercept)"]
}
}
}
return(fit_data_res)
}
signif.star <- function(x) {symnum(x, corr = FALSE, na = FALSE, legend = FALSE,
cutpoints = c(0, 1e-04, 0.001, 0.01, 0.05, 1),
symbols = c("****", "***", "**", "*", "ns"))}
p.star <- function(x) {paste(round(x, 2), signif.star(x), sep='')}
ep.star <- function(x) {paste(formatC(x, format = "e", digits = 1), signif.star(x), sep='')}
## import data
#df <- data.frame(read.csv(file = '/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/longitudinal/resid_df_skeletons_harmonized_noimputation.csv'))
df <- data.frame(read.csv(file = '/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/longitudinal/resid_df_skeletons_harmonized_noimputation_allscales.csv'))
jhu <- read.csv(file = '/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/R_scripts/jhu_labels_for_R.csv')
## remove ARMS
df <- subset(df, group != 'ARMS') #
## remove EP
#df <- subset(df, EP_to_exclude == 1)
df$clin <- df$group != 'CTRL'
#### diagnostic categories ####
df_diagnosis <- data.frame(read.csv(file = '/home/localadmin/PycharmProjects/LausannePsychosisAnalysis/longitudinal/diagnosis_only.csv'))
df <- merge(df, df_diagnosis, by = c('sub', 'ses'), all.x = TRUE)
## subset, remove NA
fit_data <- df[df$cross_sectional=='True',]
roi <- jhu$long_corrected[30]
fit_data_sk <- fit_data %>% subset(label == roi)
fit_data_sk$ageM <- fit_data_sk$ageM / 12
fit_data_sk$Duration_Psychosis_days <- fit_data_sk$Duration_Psychosis_days / 365
#fit_data_sk$Duration_Psychosis_days[fit_data_sk$Duration_Psychosis_days==0] <- NA
######### make sub control groups
min_ep <- min(fit_data_sk$ageM[fit_data_sk$group == 'EP'])
max_ep <- max(fit_data_sk$ageM[fit_data_sk$group == 'EP'])
young_ctrl <- fit_data_sk$ageM <= max_ep & fit_data_sk$ageM >= min_ep
min_sz <- min(fit_data_sk$ageM[fit_data_sk$group == 'SCHZ'])
max_sz <- max(fit_data_sk$ageM[fit_data_sk$group == 'SCHZ'])
old_ctrl <-  fit_data_sk$ageM <= max_sz & fit_data_sk$ageM >= min_sz
# new groups by duplicating rows
fit_data_sk$group2 <- fit_data_sk$group
fit_data_sk$group2[young_ctrl & fit_data_sk$group == 'CTRL'] <- 'CTRL-Y'
ctrl_to_duplicate <- fit_data_sk$group2 == 'CTRL-Y' & old_ctrl
fit_data_sk$group2[old_ctrl & fit_data_sk$group == 'CTRL'] <- 'CTRL-O'
dims <- dim(fit_data_sk)
fit_data_sk <- rbind(fit_data_sk, fit_data_sk[ctrl_to_duplicate,])
# transform only duplicates in control young
fit_data_sk[seq(dims[1]+1, dim(fit_data_sk)[1]), 'group2'] <- 'CTRL-Y'
fit_data_sk$group <- as.factor(fit_data_sk$group2)
levels(fit_data_sk$group) <- c("CTRL-O", "CTRL-Y", "EP","SCHZ")
#levels(fit_data_sk$group) <- c("HC-O", "HC-Y", "EP","SZ")
### drop extreame subject
fit_data_sk <- fit_data_sk[fit_data_sk$sub !='L478', ]
skeletons <- c("skeleton_rd","skeleton_md","skeleton_ad","skeleton_fa",
"skeleton_rk","skeleton_mk","skeleton_ak","skeleton_f",
"skeleton_da","skeleton_depar","skeleton_deperp","skeleton_c2")
sk_names <- c("$RD$  [µm²/ms]", "$MD$  [µm²/ms]",
"$AD$  [µm²/ms]",
"$FA$", "$RK$", "$MK$",
"$AK$", "$f$",
"$D_{a}$  [µm²/ms]",
"$D_{e,//}$  [µm²/ms]",
"$D_{e,\\perp}$  [µm²/ms]",
"$c_2$")
grobs_id = c('A.', 'B.', 'C.', 'D.','E.', 'F.','G.', 'H.','I.', 'J.','K.', 'L.')
confounds <- c("ageM","sex","Age_Psychosis_Threshold","group","group2",'gratio',
'gpx', 'gred',"Duration_Psychosis_days","neuroleptics", "diagnosis")
trimmed_fit_data <- fit_data_sk[c(skeletons, confounds)]
theme_set(theme_pubr())
make_plot <- function(i, stir=F, variables=skeletons, var_names=sk_names,
rm.opt.test=F, hide.ns=F,
maketable=F, precomp_comparison=NaN, inject=F) {
theme_set(theme_pubr())
sk <- variables[i]
sk_fmt_name <- var_names[i]
tmp_df <- trimmed_fit_data[c(sk, 'group')]
colnames(tmp_df)[colnames(tmp_df) == sk] <- 'value'
# sort groups
tmp_df$group <- factor(tmp_df$group, levels=c('CTRL-Y', 'EP', 'CTRL-O', 'SCHZ'))
levels(tmp_df$group) <- c('HC-Y', 'EP', 'HC-O', 'SZ')
#medians
med_hcy <- median(tmp_df[tmp_df$group == 'HC-Y','value'], na.rm=T)
med_ep <- median(tmp_df[tmp_df$group == 'EP','value'], na.rm=T)
med_hco <- median(tmp_df[tmp_df$group == 'HC-O','value'], na.rm=T)
med_sz <- median(tmp_df[tmp_df$group == 'SZ','value'], na.rm=T)
# main plot
if (! stir){
agrob <- ggplot(data = tmp_df, aes(x=group, y=value)) +
geom_boxplot(aes(fill=group)) +
scale_fill_grey(start = 0.4,
end = 0.9)
} else {
agrob <- ggplot(data = tmp_df, aes(x=group, y=value)) +
geom_jitter(position=position_jitter(0.15), aes(shape = group, alpha=0.25)) +
stat_summary(fun.data="median_hilow",
fun.args = c(conf.int=0.5),  # 25th and 75th percentiles,
colour = "red") +
geom_segment(aes(x = 'HC-Y', y = med_hcy, xend = 'EP', yend = med_ep, colour = "red"),inherit.aes =F)+
geom_segment(aes(x = 'HC-O', y = med_hco, xend = 'SZ', yend = med_sz, colour = "red"),inherit.aes =F)
}
# plot pvals
#test.res <- compare_means(value ~ group, tmp_df, method = "wilcox.test", p.adjust.method='fdr')
test.res <- wilcox_test(tmp_df, value ~ group, p.adjust.method='fdr', detailed=T)
#eff_size <- wilcox_effsize(tmp_df, value ~ group)
test.res$effsize <- 0
test.res$effsize.ci.low <- 0
test.res$effsize.ci.high <- 0
d <- cohens_d(tmp_df$value[tmp_df$group == 'EP'], tmp_df$value[tmp_df$group == 'HC-Y'])
test.res[test.res$group1 == 'HC-Y' & test.res$group2 == 'EP', 'effsize'] <- signif(d$Cohens_d, digits=2)
test.res[test.res$group1 == 'HC-Y' & test.res$group2 == 'EP', 'effsize.ci.low'] <- signif(d$CI_low, digits=2)
test.res[test.res$group1 == 'HC-Y' & test.res$group2 == 'EP', 'effsize.ci.high'] <- signif(d$CI_high, digits=2)
d <- cohens_d(tmp_df$value[tmp_df$group == 'SZ'], tmp_df$value[tmp_df$group == 'HC-O'])
test.res[test.res$group1 == 'HC-O' & test.res$group2 == 'SZ', 'effsize'] <- signif(d$Cohens_d, digits=2)
test.res[test.res$group1 == 'HC-O' & test.res$group2 == 'SZ', 'effsize.ci.low'] <- signif(d$CI_low, digits=2)
test.res[test.res$group1 == 'HC-O' & test.res$group2 == 'SZ', 'effsize.ci.high'] <- signif(d$CI_high, digits=2)
if (inject){
k = i-1
a=2
test.res[c(1, 6),"p.adj"] <- precomp_comparison[(k*a+1):(k*a+a), "p.adj"]
}
# drop useless comparisons
if (rm.opt.test) {
test.res[c(2, 3, 4, 5), 'p.adj'] <- 1
test.res[c(2, 3, 4, 5), 'p'] <- 1
}
# fix signif star
test.res$p.adj.signif <- signif.star(test.res$p.adj)
test.res$p.adj <- format(test.res$p.adj, scientific = TRUE, trim=T, digits=3)
ylims <- layer_scales(agrob)$y$get_limits()
yrange = ylims[2] - ylims[1]
upper = ylims[2] + yrange * 0.075  # 95%of the tot length
step = yrange * 0.175  # 5% decrements
test.res <- test.res %>% mutate(y.position = c(upper+step, upper+4*step, upper+5*step,
upper+2*step, upper+3*step, upper))
agrob <- agrob + stat_pvalue_manual(test.res, label = "{p.adj}{p.adj.signif}", hide.ns=hide.ns) +
coord_cartesian(clip = 'off')
# titles and axis naming
strsplit(sk, '_')[1]
agrob <- agrob + ylab(TeX(sk_fmt_name)[1]) + xlab("Group")
agrob <- agrob + theme(legend.position = "none", plot.title.position = "plot")
agrob <- agrob +scale_x_discrete(labels=c("HC-Y" = TeX("$HC_{Young}$")[1],
"EP" = TeX('$EP$')[1],
"HC-O" = TeX("$HC_{Old}$")[1],
"SZ" = TeX("$SZ$")[1]))
#agrob <- agrob + labs(title = TeX(grobs_id[i]))
if (maketable==F){
return(agrob)
} else {
test.res$metric_org <- sk
test.res$metric <- sk_fmt_name
test.res$metric[2:6] <- ''
col_name <- c("metric_org", "metric", "group1","group2","estimate",
"conf.low","conf.high", "p", "p.adj","p.adj.signif","effsize",
'effsize.ci.low', 'effsize.ci.high')
return(test.res[c(1, 6), col_name])
}
}
# not controlled for covariates
#grobs_list <- lapply(1:12, make_plot)
#ggarrange(plotlist = grobs_list)
